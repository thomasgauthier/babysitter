        return emit_json_data(payload)
    print(message)
    return 0


def session_status_value(session: dict) -> str:
    if session.get("active") and process_alive(session.get("launcher_pid")):
        return "active"
    if session.get("active"):
        return "stale"
    return "stopped"


def status_payload(session: dict) -> dict:
    runtime = ensure_runtime_state(session)
    requests = ordered_pending_requests(session)
    payload = {
        "session_name": session.get("session_name"),
        "status": session_status_value(session),
        "model": session.get("model"),
        "run_dir": session.get("run_dir"),
        "turn_state": runtime.get("last_turn_state", "idle"),
        "pending_request_count": len(requests),
        "pending_request_ids": [request.get("id") for request in requests if request.get("id")],
    }
    stop_reason = runtime.get("last_stop_reason") or session.get("stop_reason")
    if isinstance(stop_reason, str) and stop_reason:
        payload["stop_reason"] = stop_reason
    return payload


def require_pending_request(session: dict, request_id: str, expected_method: str | None = None) -> dict:
    runtime = ensure_runtime_state(session)
    request = runtime["pending_requests"].get(request_id)
    if not isinstance(request, dict):
        fail(f"unknown request id {request_id}; run {cli_name()} requests")

    method = request.get("method")
    if expected_method and method != expected_method:
        fail(f"request {request_id} is method={method}; expected {expected_method}")
    return request


def require_select_option(request: dict, option: str) -> None:
    options = request.get("options")
    if not isinstance(options, list) or option not in options:
        fail(f"request {request.get('id')} does not offer option {option!r}")


def send_request_response(
    args: argparse.Namespace,
    request_id: str,
    *,
    expected_method: str | None = None,
    value: str | None = None,
    confirmed: bool | None = None,
    cancelled: bool = False,
    command_name: str,
    message: str,
) -> int:
    session = require_live_session()
    request = require_pending_request(session, request_id, expected_method=expected_method)
    payload: dict = {"type": "extension_ui_response", "id": request_id}
    if cancelled:
        payload["cancelled"] = True
    elif confirmed is not None:
        payload["confirmed"] = confirmed
    else:
        payload["value"] = value
    send_payload(session, payload)
    return emit_command_success(
        args,
        command_name,
        message,
        request_id=request_id,
        method=request.get("method"),
        sent=payload,
    )


