def load_session_or_fail() -> dict:
    session = load_session()
    if not session:
        fail("no session metadata found")
    return session


def require_live_session() -> dict:
    session = load_session_or_fail()
    if not active_session(session):
        fail("no active session")
    if not process_alive(session.get("launcher_pid")):
        save_session(mark_inactive(session, "process exited before send"))
        fail("active session is stale; process is not running")
    return session


def read_text_source(args: argparse.Namespace) -> str:
    sources = [
        ("--text", getattr(args, "text", None)),
        ("--file", getattr(args, "file", None)),
        ("--stdin", getattr(args, "stdin", False)),
    ]
    selected = [name for name, value in sources if value not in (None, False)]
    if len(selected) != 1:
        fail("choose exactly one of --text, --file, or --stdin")

    if getattr(args, "text", None) is not None:
        text = str(args.text)
    elif getattr(args, "file", None) is not None:
        file_path = str(args.file)
        if file_path == "-":
            fail("use --stdin to read from standard input")
        path = Path(file_path)
        try:
            text = path.read_text(encoding="utf-8")
        except OSError as exc:
            fail(f"could not read {path}: {exc}")
    else:
        text = sys.stdin.read()

    if not text:
        fail("message content is empty")
    return text


def send_payload(session: dict, payload: dict, raw_payload: str | None = None) -> None:
    body = raw_payload if raw_payload is not None else json.dumps(payload, ensure_ascii=False)
    write_fifo_line(Path(session["stdin_fifo"]), body)

    if payload.get("type") == "extension_ui_response":
        request_id = payload.get("id")
        if isinstance(request_id, str) and request_id:
            mark_request_resolved(session, request_id)
            clear_pending_request(session, request_id)

    save_session(session)


def emit_command_success(args: argparse.Namespace, command: str, message: str, **details: object) -> int:
