def stop_process_group(pid: int) -> None:
    try:
        os.killpg(pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    deadline = time.time() + 2.0
    while time.time() < deadline:
        if not process_alive(pid):
            return
        time.sleep(0.1)
    try:
        os.killpg(pid, signal.SIGKILL)
    except ProcessLookupError:
        return


def cmd_stop(_args: argparse.Namespace) -> int:
    session = load_session()
    if not active_session(session):
        fail("no active session")

    fifo_path = Path(session["stdin_fifo"])
    if fifo_path.exists() and process_alive(session.get("launcher_pid")):
        try:
            write_fifo_line(fifo_path, json.dumps({"type": "abort"}))
        except SystemExit:
            pass
        time.sleep(0.3)

    pid = session.get("launcher_pid")
    if pid and process_alive(pid):
        stop_process_group(pid)

    session = mark_inactive(session, "stopped by babysitter stop")
    save_session(session)
    print(f"stopped {session['session_name']}")
    return 0


