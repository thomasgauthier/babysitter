def cmd_poll(args: argparse.Namespace) -> int:
    session = load_session_or_fail()

    if args.raw:
        chunk = read_raw_chunk(session)
        if not chunk:
            print("no new messages")
            return 0
        sys.stdout.write(chunk.decode("utf-8", errors="replace"))
        if chunk and not chunk.endswith(b"\n"):
            sys.stdout.write("\n")
        return 0

    mode = "json" if args.json else "pretty"
    lines = read_jsonl_lines(session, mode)
    poll_state = ensure_poll_state(session)
    mode_state = poll_state[mode]
    events, carry_reasoning, carry_assistant_text = build_semantic_events(
        lines,
        str(mode_state.get("carry_reasoning", "")),
        str(mode_state.get("carry_assistant_text", "")),
    )
    pending_text = str(mode_state.get("pending", ""))
    apply_semantic_events_to_runtime(session, events)
    annotate_request_events(session, events)
    if pending_text:
        events.append(build_streaming_output_event(pending_text))
    mode_state["carry_reasoning"] = carry_reasoning
    mode_state["carry_assistant_text"] = carry_assistant_text
    save_session(session)
    if args.json:
        return emit_json_events(events)
    return emit_pretty_events(events)


