def eprint(message: str) -> None:
    print(message, file=sys.stderr)


def fail(message: str, exit_code: int = 1) -> None:
    eprint(message)
    raise SystemExit(exit_code)


def repo_root() -> Path:
    return Path(__file__).resolve().parent


def cli_name() -> str:
    return Path(sys.argv[0]).name or "babysitter"


def state_path() -> Path:
    return repo_root() / STATE_DIR / CURRENT_SESSION.name


def ensure_state_dir() -> None:
    (repo_root() / STATE_DIR).mkdir(parents=True, exist_ok=True)


def load_session() -> dict | None:
    path = state_path()
    if not path.exists():
        return None
    return json.loads(path.read_text(encoding="utf-8"))


def save_session(session: dict) -> None:
    ensure_state_dir()
    state_path().write_text(json.dumps(session, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def ensure_poll_state(session: dict) -> dict:
    state = session.setdefault("poll_state", {})
    legacy_json_state = state.get("jsonl") if isinstance(state.get("jsonl"), dict) else None
    for mode in POLL_MODES:
        mode_state = state.setdefault(mode, {})
        mode_state.setdefault("offset", 0)
        if mode != "raw":
            mode_state.setdefault("pending", "")
            mode_state.setdefault("carry_reasoning", "")
            mode_state.setdefault("carry_assistant_text", "")
    if legacy_json_state:
        json_state = state["json"]
        for key in ("offset", "pending", "carry_reasoning", "carry_assistant_text"):
            if key in legacy_json_state and not json_state.get(key):
                json_state[key] = legacy_json_state.get(key)
    if "stdout_offset" in session:
        state["raw"]["offset"] = max(int(session.get("stdout_offset", 0)), int(state["raw"].get("offset", 0)))
    return state


def ensure_runtime_state(session: dict) -> dict:
    runtime = session.setdefault("runtime", {})

    pending_requests = runtime.get("pending_requests")
    if not isinstance(pending_requests, dict):
        pending_requests = {}
    runtime["pending_requests"] = pending_requests

    pending_request_order = runtime.get("pending_request_order")
    if not isinstance(pending_request_order, list):
        pending_request_order = []
    runtime["pending_request_order"] = pending_request_order

    resolved_request_ids = runtime.get("resolved_request_ids")
    if not isinstance(resolved_request_ids, list):
        resolved_request_ids = []
    runtime["resolved_request_ids"] = resolved_request_ids

    last_turn_state = runtime.get("last_turn_state")
    if not isinstance(last_turn_state, str) or not last_turn_state:
        runtime["last_turn_state"] = "idle"

    last_stop_reason = runtime.get("last_stop_reason")
    if last_stop_reason is not None and not isinstance(last_stop_reason, str):
        runtime["last_stop_reason"] = str(last_stop_reason)
    return runtime


def clear_pending_request(session: dict, request_id: str) -> None:
    runtime = ensure_runtime_state(session)
    runtime["pending_requests"].pop(request_id, None)
    runtime["pending_request_order"] = [
        pending_id for pending_id in runtime["pending_request_order"] if pending_id != request_id
    ]


def mark_request_resolved(session: dict, request_id: str) -> None:
    runtime = ensure_runtime_state(session)
    if request_id not in runtime["resolved_request_ids"]:
        runtime["resolved_request_ids"].append(request_id)


def ordered_pending_requests(session: dict) -> list[dict]:
    runtime = ensure_runtime_state(session)
    pending_requests = runtime["pending_requests"]
    ordered: list[dict] = []
    seen: set[str] = set()

    for request_id in runtime["pending_request_order"]:
        payload = pending_requests.get(request_id)
        if isinstance(payload, dict):
            ordered.append(payload)
            seen.add(request_id)

    for request_id, payload in pending_requests.items():
        if request_id not in seen and isinstance(payload, dict):
            ordered.append(payload)

    return ordered


def process_alive(pid: int | None) -> bool:
    if not pid:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def active_session(session: dict | None) -> dict | None:
    if not session:
        return None
    if not session.get("active"):
        return None
    return session


def stale_active_session(session: dict | None) -> bool:
    return bool(session and session.get("active") and not process_alive(session.get("launcher_pid")))


def choose_session_name() -> str:
    base = int(time.time())
    adj = ADJECTIVES[base % len(ADJECTIVES)]
    noun = NOUNS[(base // len(ADJECTIVES)) % len(NOUNS)]
    root = repo_root() / RUNS_DIR
    root.mkdir(parents=True, exist_ok=True)
    candidate = f"{adj}-{noun}"
    if not (root / candidate).exists():
        return candidate
    suffix = 2
    while (root / f"{candidate}-{suffix}").exists():
        suffix += 1
    return f"{candidate}-{suffix}"


def copy_workspace_template(run_dir: Path) -> None:
    src = repo_root() / WORKSPACE_TEMPLATE_DIR
    if not src.is_dir():
        fail(f"missing workspace template: {src}")
    run_dir.mkdir(parents=True, exist_ok=True)
    for entry in src.iterdir():
        if entry.name in EPHEMERAL_LINT_CONFIGS:
            continue
        target = run_dir / entry.name
        if entry.is_dir():
            shutil.copytree(entry, target, dirs_exist_ok=True)
        else:
            shutil.copy2(entry, target)


def seed_project_system_prompt(run_dir: Path) -> None:
    source = repo_root() / SYSTEM_PROMPT_SOURCE
    if not source.is_file():
        fail(f"missing system prompt source: {source}")
    target = run_dir / ".pi" / "SYSTEM.md"
    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, target)


def build_pi_command(run_dir: Path, model: str, extra_args: list[str]) -> str:
    cmd = [
        "pi",
        "--mode",
        "rpc",
        "--no-extensions",
        "-e",
        str(repo_root() / EXTENSIONS_DIR / "live-host-approval.ts"),
        "-e",
        str(repo_root() / EXTENSIONS_DIR / "selene-on-lua-write.ts"),
        "--no-skills",
        "--skill",
        str(repo_root() / "skills" / "tic80ctl-usage"),
        "--no-prompt-templates",
        "--model",
        model,
        *extra_args,
    ]
    escaped = " ".join(shlex.quote(part) for part in cmd)
    return f"cd {shlex.quote(str(run_dir))} && {escaped}"


def build_launch_command(run_dir: Path, stdin_fifo: Path, model: str, extra_args: list[str]) -> str:
    pi_command = build_pi_command(run_dir, model, extra_args)
    return f"tail -f -- {shlex.quote(str(stdin_fifo))} | bash -lc {shlex.quote(pi_command)}"


def write_fifo_line(fifo_path: Path, payload: str) -> None:
    data = payload if payload.endswith("\n") else f"{payload}\n"
    try:
        fd = os.open(fifo_path, os.O_WRONLY | os.O_NONBLOCK)
    except FileNotFoundError:
        fail(f"stdin fifo is missing: {fifo_path}")
    except OSError as exc:
        fail(f"could not open stdin fifo for writing: {exc}")
    try:
        os.write(fd, data.encode("utf-8"))
    finally:
        os.close(fd)


def mark_inactive(session: dict, reason: str | None = None) -> dict:
    session = dict(session)
    session["active"] = False
    session["stopped_at"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    runtime = ensure_runtime_state(session)
    runtime["last_turn_state"] = "stopped"
    runtime["pending_requests"] = {}
    runtime["pending_request_order"] = []
    if reason:
        session["stop_reason"] = reason
        runtime["last_stop_reason"] = reason
    return session


def cmd_new(args: argparse.Namespace) -> int:
    session = load_session()
    if active_session(session) and process_alive(session.get("launcher_pid")):
        fail(f"active session already exists: {session['session_name']} at {session['run_dir']}")
    if stale_active_session(session):
        save_session(mark_inactive(session, "stale session replaced by babysitter new"))

    session_name = choose_session_name()
    run_dir = repo_root() / RUNS_DIR / session_name
    stdin_fifo = run_dir / "stdin"
    stdout_log = run_dir / "stdout"
    stderr_log = run_dir / "stderr"

    copy_workspace_template(run_dir)
    seed_project_system_prompt(run_dir)
    stdout_log.touch()
    stderr_log.touch()
    if stdin_fifo.exists():
        stdin_fifo.unlink()
    os.mkfifo(stdin_fifo)

    command = build_launch_command(run_dir, stdin_fifo, args.model, args.extra_args)
    with stdout_log.open("ab") as stdout_handle, stderr_log.open("ab") as stderr_handle:
        process = subprocess.Popen(
            ["nohup", "bash", "-lc", command],
            cwd=repo_root(),
            stdin=subprocess.DEVNULL,
            stdout=stdout_handle,
            stderr=stderr_handle,
            start_new_session=True,
        )
    time.sleep(0.3)
    if process.poll() is not None:
        fail(f"launch failed; inspect {stderr_log}")

    session_data = {
        "active": True,
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "launcher_pid": process.pid,
        "model": args.model,
        "poll_state": {
            "json": {"offset": 0, "pending": ""},
            "pretty": {"offset": 0, "pending": ""},
            "raw": {"offset": 0},
        },
        "run_dir": str(run_dir),
        "runtime": {
            "last_stop_reason": None,
            "last_turn_state": "idle",
            "pending_request_order": [],
            "pending_requests": {},
            "resolved_request_ids": [],
        },
        "session_name": session_name,
        "stderr_log": str(stderr_log),
        "stdin_fifo": str(stdin_fifo),
        "stdout_log": str(stdout_log),
        "stdout_offset": 0,
    }
    save_session(session_data)
    print(f"new session {session_name} started at {run_dir}")
    return 0


def read_new_bytes(stdout_log: Path, offset: int) -> tuple[bytes, int]:
    size = stdout_log.stat().st_size
    if size < offset:
        offset = 0
    with stdout_log.open("rb") as handle:
        handle.seek(offset)
        chunk = handle.read()
    return chunk, offset + len(chunk)


def read_raw_chunk(session: dict) -> bytes:
    stdout_log = Path(session["stdout_log"])
    if not stdout_log.exists():
        fail(f"stdout log is missing: {stdout_log}")

    poll_state = ensure_poll_state(session)
    mode_state = poll_state["raw"]
    chunk, next_offset = read_new_bytes(stdout_log, int(mode_state.get("offset", 0)))
    mode_state["offset"] = next_offset
    session["stdout_offset"] = next_offset
    save_session(session)
    return chunk


def read_jsonl_lines(session: dict, mode: str) -> list[str]:
    stdout_log = Path(session["stdout_log"])
    if not stdout_log.exists():
        fail(f"stdout log is missing: {stdout_log}")

    poll_state = ensure_poll_state(session)
    mode_state = poll_state[mode]
    chunk, next_offset = read_new_bytes(stdout_log, int(mode_state.get("offset", 0)))
    pending = str(mode_state.get("pending", ""))
    text = pending + chunk.decode("utf-8", errors="replace")

    if not text:
        mode_state["offset"] = next_offset
        mode_state["pending"] = pending
        save_session(session)
        return []

    lines = text.splitlines(keepends=True)
    complete_lines: list[str] = []
    next_pending = ""

    for line in lines:
        if line.endswith("\n") or line.endswith("\r"):
            complete_lines.append(line.rstrip("\r\n"))
        else:
            next_pending += line

    mode_state["offset"] = next_offset
    mode_state["pending"] = next_pending
    save_session(session)
    return complete_lines


def extract_text_content(payload: dict | None) -> str:
    if not isinstance(payload, dict):
        return ""
    content = payload.get("content")
    if not isinstance(content, list):
        return ""
    parts: list[str] = []
    for item in content:
        if isinstance(item, dict) and item.get("type") == "text":
            text = item.get("text")
            if isinstance(text, str):
                parts.append(text)
    return "".join(parts)


def shorten(text: str, max_length: int = 160) -> str:
    normalized = " ".join(text.split())
    if len(normalized) <= max_length:
        return normalized
    return f"{normalized[: max_length - 3]}..."


def flush_buffer(events: list[dict], kind: str, parts: list[str]) -> None:
    text = "".join(parts)
    if text.strip():
        events.append({"type": kind, "text": text})
    parts.clear()


def flush_message_buffers(events: list[dict], reasoning_parts: list[str], assistant_parts: list[str]) -> None:
    flush_buffer(events, "reasoning", reasoning_parts)
    flush_buffer(events, "assistant_text", assistant_parts)


def translate_event(obj: dict, reasoning_parts: list[str], assistant_parts: list[str], translated: list[dict]) -> None:
    event_type = obj.get("type")
    if event_type == "message_update":
        assistant_event = obj.get("assistantMessageEvent", {})
        assistant_event_type = assistant_event.get("type")
        if assistant_event_type == "thinking_delta":
            delta = assistant_event.get("delta")
            if isinstance(delta, str):
                reasoning_parts.append(delta)
        elif assistant_event_type == "text_delta":
            delta = assistant_event.get("delta")
            if isinstance(delta, str):
                assistant_parts.append(delta)
        return

    if event_type in {"message_start", "message_end"}:
        return

    if event_type == "extension_ui_request":
        method = obj.get("method")
        if method in {"setStatus", "setWidget", "setTitle"}:
            return
        if method == "notify":
            message = obj.get("message")
            if isinstance(message, str) and message.startswith("[host] "):
                flush_message_buffers(translated, reasoning_parts, assistant_parts)
                translated.append(
                    {
                        "type": "host_policy_result",
                        "message": message.removeprefix("[host] ").strip(),
                    }
                )
                return
            # Preserve non-host notifications in filtered views.
        flush_message_buffers(translated, reasoning_parts, assistant_parts)
        entry = {"type": "extension_ui_request", "method": method}
        for key, value in obj.items():
            if key in {"type", "method"}:
                continue
            if isinstance(value, (str, int, float, bool)) or value is None or isinstance(value, (list, dict)):
                entry[key] = value
        translated.append(entry)
        return

    if event_type == "tool_execution_start":
        flush_message_buffers(translated, reasoning_parts, assistant_parts)
        translated.append(
            {
                "type": "tool_execution_start",
                "toolName": obj.get("toolName"),
                "args": obj.get("args", {}),
            }
        )
        return

    if event_type == "tool_execution_update":
        flush_message_buffers(translated, reasoning_parts, assistant_parts)
        content = extract_text_content(obj.get("partialResult"))
        if content.strip():
            translated.append(
                {
                    "type": "tool_execution_update",
                    "toolCallId": obj.get("toolCallId"),
                    "toolName": obj.get("toolName"),
                    "text": content,
                }
            )
        return

    if event_type == "tool_execution_end":
        flush_message_buffers(translated, reasoning_parts, assistant_parts)
        translated.append(
            {
                "type": "tool_execution_end",
                "toolCallId": obj.get("toolCallId"),
                "toolName": obj.get("toolName"),
                "isError": bool(obj.get("isError")),
                "text": extract_text_content(obj.get("result")),
            }
        )
        return

    if event_type in {"agent_start", "turn_start", "turn_end", "response"}:
        flush_message_buffers(translated, reasoning_parts, assistant_parts)
        if event_type == "turn_end":
            translated.append(
                {
                    "type": "turn_end",
                    "stopReason": obj.get("message", {}).get("stopReason"),
                }
            )
            return
        if event_type == "response":
            entry = {"type": "response", "command": obj.get("command"), "success": obj.get("success")}
            details = {key: value for key, value in obj.items() if key not in {"type", "command", "success"}}
            if details:
                entry["details"] = details
            translated.append(entry)
            return
        translated.append({"type": event_type})


def build_semantic_events(lines: list[str], carry_reasoning: str = "", carry_assistant_text: str = "") -> tuple[list[dict], str, str]:
    translated: list[dict] = []
    reasoning_parts: list[str] = [carry_reasoning] if carry_reasoning else []
    assistant_parts: list[str] = [carry_assistant_text] if carry_assistant_text else []

    for line in lines:
        raw = line.strip()
        if not raw:
            continue
        try:
            obj = json.loads(raw)
        except json.JSONDecodeError:
            continue
        if not isinstance(obj, dict):
            continue
        translate_event(obj, reasoning_parts, assistant_parts, translated)

    flush_message_buffers(translated, reasoning_parts, assistant_parts)

    deduped: list[dict] = []
    skip_indexes: set[int] = set()
    for index, event in enumerate(translated):
        if event.get("type") != "tool_execution_update":
            continue
        tool_call_id = event.get("toolCallId")
        if not tool_call_id:
            continue
        for next_index in range(index + 1, len(translated)):
            candidate = translated[next_index]
            if candidate.get("type") == "tool_execution_end" and candidate.get("toolCallId") == tool_call_id:
                if candidate.get("text") == event.get("text"):
                    skip_indexes.add(index)
                break
    for index, event in enumerate(translated):
        if index not in skip_indexes:
            deduped.append(event)

    coalesced: list[dict] = []
    for event in deduped:
        if (
            coalesced
            and event.get("type") in {"reasoning", "assistant_text"}
            and coalesced[-1].get("type") == event.get("type")
        ):
            coalesced[-1]["text"] = f"{coalesced[-1].get('text', '')}{event.get('text', '')}"
            continue
        coalesced.append(event)
    return coalesced, "", ""


def build_streaming_output_event(pending_text: str) -> dict:
    return {
        "type": "streaming_output",
        "pending_bytes": len(pending_text.encode("utf-8")),
        "preview": shorten(pending_text, 240),
    }


def apply_semantic_events_to_runtime(session: dict, events: list[dict]) -> None:
    runtime = ensure_runtime_state(session)
    resolved_request_ids = set(runtime["resolved_request_ids"])
    for event in events:
        event_type = event.get("type")
        if event_type == "agent_start":
            runtime.setdefault("last_turn_state", "idle")
            continue
        if event_type == "turn_start":
            runtime["last_turn_state"] = "running"
            runtime["last_stop_reason"] = None
            continue
        if event_type == "turn_end":
            runtime["last_turn_state"] = "stopped"
            runtime["last_stop_reason"] = event.get("stopReason")
            continue
        if event_type != "extension_ui_request":
            continue

        request_id = event.get("id")
        method = event.get("method")
        if not isinstance(request_id, str) or not request_id or method not in ACTIONABLE_REQUEST_METHODS:
            continue
        if request_id in resolved_request_ids:
            continue

        runtime["pending_requests"][request_id] = dict(event)
        if request_id not in runtime["pending_request_order"]:
            runtime["pending_request_order"].append(request_id)


def annotate_request_events(session: dict, events: list[dict]) -> None:
    runtime = ensure_runtime_state(session)
    pending_request_ids = set(runtime["pending_requests"])
    resolved_request_ids = set(runtime["resolved_request_ids"])

    for event in events:
        if event.get("type") != "extension_ui_request":
            continue
        request_id = event.get("id")
        method = event.get("method")
        if not isinstance(request_id, str) or not request_id or method not in ACTIONABLE_REQUEST_METHODS:
            continue

        is_pending = request_id in pending_request_ids
        event["pending"] = is_pending
        if not is_pending and request_id in resolved_request_ids:
            event["resolved"] = True


def render_ui_request_body(event: dict) -> str:
    lines: list[str] = []
    request_id = str(event.get("id") or "").strip()
    if request_id:
        lines.append(f"request id: {request_id}")

    title = event.get("title")
    if isinstance(title, str) and title.strip():
        lines.append(title.rstrip())

    message = event.get("message")
    if isinstance(message, str) and message.strip():
        normalized_title = title.strip() if isinstance(title, str) else ""
        normalized_message = message.strip()
        if normalized_message != normalized_title:
            lines.append(normalized_message)

    text = event.get("text")
    if isinstance(text, str) and text.strip():
        lines.append(f"text:\n{text.rstrip()}")

    value = event.get("value")
    if isinstance(value, str) and value.strip():
        lines.append(f"value:\n{value.rstrip()}")

    placeholder = event.get("placeholder")
    if isinstance(placeholder, str) and placeholder.strip():
        lines.append(f"placeholder: {placeholder.rstrip()}")

    extras = {
        key: value
        for key, value in event.items()
        if key
        not in {
            "type",
            "method",
            "id",
            "pending",
            "resolved",
            "title",
            "message",
            "text",
            "value",
            "placeholder",
            "options",
        }
    }
    if extras:
        lines.append(json.dumps(extras, ensure_ascii=False, indent=2))
    return "\n".join(lines)


def format_pretty_event(event: dict) -> str:
    event_type = event.get("type")
    if event_type == "reasoning":
        return f"reasoning:\n{event['text'].rstrip()}"
    if event_type == "assistant_text":
        return f"assistant:\n{event['text'].rstrip()}"
    if event_type == "extension_ui_request":
        method = event.get("method")
        body = render_ui_request_body(event)
        suffix = ", not pending" if event.get("pending") is False else ""
        if method == "select":
            options = " | ".join(str(option) for option in event.get("options", []))
            header = f"tool policy check{suffix}:"
            return f"{header}\n{body}\noptions: {options}" if body else f"{header}\noptions: {options}"
        header = f"ui request ({method}{suffix}):" if method else f"ui request{suffix}:"
        return f"{header}\n{body}" if body else header.rstrip(":")
    if event_type == "host_policy_result":
        return f"tool policy result: {event.get('message')}"
    if event_type == "tool_execution_start":
        args = event.get("args", {})
        if isinstance(args, dict) and args:
            arg_parts = ", ".join(f"{key}={repr(value)}" for key, value in args.items())
            return f"tool start: {event.get('toolName')}({arg_parts})"
        return f"tool start: {event.get('toolName')}"
    if event_type == "tool_execution_update":
        text = str(event.get("text", "")).rstrip()
        return (
            f"tool output: {event.get('toolName')}\n{text}"
            if text
            else f"tool output: {event.get('toolName')}"
        )
    if event_type == "tool_execution_end":
        status = "error" if event.get("isError") else "ok"
        text = str(event.get("text", "")).rstrip()
        header = f"tool output: {event.get('toolName')} [{status}]"
        return f"{header}\n{text}" if text else header
    if event_type == "agent_start":
        return "agent start"
    if event_type == "turn_start":
        return "turn start"
    if event_type == "turn_end":
        stop_reason = event.get("stopReason")
        return f"turn end ({stop_reason})" if stop_reason else "turn end"
    if event_type == "response":
        details = event.get("details")
        header = f"response: command={event.get('command')} success={event.get('success')}"
        if details:
            return f"{header}\n{json.dumps(details, ensure_ascii=False, indent=2)}"
        return header
    if event_type == "streaming_output":
        pending_bytes = event.get("pending_bytes")
        preview = event.get("preview")
        header = "streaming output buffered"
        if isinstance(pending_bytes, int):
            header = f"{header} ({pending_bytes} bytes)"
        if isinstance(preview, str) and preview.strip():
            return f"{header}:\n{preview}"
        return header
    return json.dumps(event, ensure_ascii=False, indent=2)


